# livecv — environment variables for consumer apps.
#
# Copy this file to `.env.local` in your Next.js app (NOT in the livecv
# package itself — env vars live in the app that calls createHandler).
#
# In production, set these in your hosting provider's dashboard:
#   Vercel → Project Settings → Environment Variables
#   (scope to Production + Preview + Development)

# ─── Required ──────────────────────────────────────────────────────

# Anthropic API key — used by livecv's createHandler() via @ai-sdk/anthropic.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional ──────────────────────────────────────────────────────

# Override the default model (set via config.model in livecv.config.ts).
# If you set it here instead, read it in your handler config:
#   model: process.env.LIVECV_MODEL ?? "claude-haiku-4-5"
# LIVECV_MODEL=claude-sonnet-4-6

# Upstash Redis — only needed if you wire @upstash/ratelimit on top of
# createHandler() for abuse protection. v0.1 of livecv doesn't include
# rate limiting; see README for the pattern.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
